---
import '../styles/theme.css';
import '../styles/index.css';
import { SITE } from '@/config';
const { icon } = SITE;
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta name='viewport' content='width=device-width' />

<link rel='icon' href='/favicon.ico' />
<link rel='icon' type='image/png' sizes='32x32' href='/icon-32.png' />
<link rel='icon' type='image/png' sizes='144x144' href={icon} />
<link rel='apple-touch-icon' sizes='144x144' href={icon} />
<link rel='sitemap' href='/sitemap.xml' />
<!-- Canonical URL is handled in HeadSEO.astro (included via BaseLayout) -->

<!-- Note: This CSS loads font subsets ONLY. The 8.6MB fallback has been removed for performance. -->
<link rel='stylesheet' href='/fonts/jinkai.css' />

<script is:inline>
  (() => {
    const storageKey = 'preferred-language';
    const normalizePath = (path) => (path === '/' ? '/' : path.replace(/\/$/, ''));
    const getCurrentLang = (path) => (path === '/en' || path.startsWith('/en/') ? 'en' : 'zh');
    const toLangPath = (path, lang) => {
      const normalizedPath = normalizePath(path);
      const basePath = normalizedPath.replace(/^\/en(?=\/|$)/, '') || '/';
      if (lang === 'zh') return basePath;
      return basePath === '/' ? '/en' : `/en${basePath}`;
    };

    document.addEventListener('click', (event) => {
      const target = event.target instanceof Element ? event.target.closest('[data-lang-switch]') : null;
      if (!target) return;
      const nextLang = target.getAttribute('data-lang-switch');
      if (nextLang === 'zh' || nextLang === 'en') {
        localStorage.setItem(storageKey, nextLang);
      }
    });

    const currentPath = normalizePath(window.location.pathname);
    const currentLang = getCurrentLang(currentPath);
    const savedLang = localStorage.getItem(storageKey);
    const browserLang = (navigator.languages?.[0] || navigator.language || '').toLowerCase().startsWith('en') ? 'en' : 'zh';
    const preferredLang = savedLang === 'zh' || savedLang === 'en' ? savedLang : browserLang;
    const targetPath = toLangPath(currentPath, preferredLang);

    if (targetPath !== currentPath) {
      window.location.replace(`${targetPath}${window.location.search}${window.location.hash}`);
    }
  })();
</script>
