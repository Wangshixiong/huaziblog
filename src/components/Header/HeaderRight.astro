---
import { SITE } from '@/config';
import HeaderLink from './HeaderLink.astro';
import Search from './Search.astro';
import { getLangFromUrl, useTranslations, useLocalizedPath, getAlternateLangPath } from '../../i18n/utils';

const { githubId, blogPage } = SITE;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useLocalizedPath(lang);
const nextLang = lang === 'en' ? 'zh' : 'en';
const switchPath = getAlternateLangPath(Astro.url.pathname, nextLang);
---

<div class='flex-grow text-right flex items-center justify-end gap-4'>
  <HeaderLink href={translatePath('/')} class='hidden md:inline-flex'>{t('nav.home')}</HeaderLink>
  <HeaderLink href={blogPage} target='_blank' class='hidden md:inline-flex'>{t('nav.blog')}</HeaderLink>
  <HeaderLink href={translatePath('/about')} class='hidden md:inline-flex'>{t('nav.about')}</HeaderLink>
  <HeaderLink href={`https://github.com/${githubId}`} target='_blank' class='hidden md:inline-flex'>{t('nav.github')}</HeaderLink>

  <Search />
  <a
    href={switchPath}
    data-lang-switch={nextLang}
    class='flex items-center justify-center h-9 w-9 rounded-full !bg-gray-100 dark:!bg-gray-800 text-sm font-medium transition-colors !text-gray-600 dark:!text-gray-400 hover:!text-gray-900 dark:hover:!text-gray-200'
    aria-label={lang === 'en' ? 'Switch to Chinese' : 'Switch to English'}
    style='text-decoration: none;'
  >
    {lang === 'en' ? '中' : 'En'}
  </a>
</div>
